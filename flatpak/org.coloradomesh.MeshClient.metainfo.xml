<component type="desktop-application">
  <id>org.coloradomesh.MeshClient</id>
  <name>Mesh Client</name>
  <summary>Meshtastic and MeshCore radio network client</summary>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <description>
    <p>
      Mesh Client is a desktop application for communicating with Meshtastic
      and MeshCore radio mesh networks via Bluetooth LE, USB serial, and MQTT.
      It supports diagnostics, channel management, node mapping, and direct
      messaging across both protocols simultaneously.
    </p>
  </description>
