{
  "name": "mesh-client",
  "version": "5.19.3",
  "description": "Cross-platform Electron desktop client for Meshtastic and MeshCore on macOS, Linux, and Windows — BLE, USB serial, Wi-Fi/TCP, MQTT, local SQLite history, routing diagnostics, and keyboard-first workflows.",
  "keywords": [
    "meshtastic",
    "mesh-network",
    "bluetooth",
    "mqtt",
    "electron",
    "desktop"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Colorado-Mesh/mesh-client"
  },
  "license": "MIT",
  "author": {
    "name": "Colorado Mesh",
    "email": "nv0n@coloradomesh.org"
  },
  "contributors": [
    "Joey Stanford https://github.com/rinchen",
    "dude.eth https://github.com/defidude",
    "megabear - KD5IHC"
  ],
  "main": "dist-electron/main/index.js",
  "scripts": {
    "build": "pnpm run build:main:prod && pnpm run build:preload && pnpm run build:renderer",
    "build:main": "node scripts/esbuild-main-build.mjs",
    "build:main:meta": "node scripts/esbuild-main-build.mjs --metafile=dist-electron/main/metafile.json",
    "build:main:minify-meta": "node scripts/esbuild-main-build.mjs --minify --metafile=dist-electron/main/meta.json",
    "build:main:prod": "node scripts/esbuild-main-build.mjs --minify",
    "build:main:size": "node scripts/print-main-bundle-size.mjs",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --outfile=dist-electron/preload/index.js --external:electron --format=cjs",
    "build:renderer": "vite build",
    "check:codeql-extensions": "node scripts/check-codeql-extensions.mjs",
    "check:console-log": "node scripts/check-console-log.mjs",
    "check:db-migrations": "node scripts/check-db-migrations.mjs",
    "check:electron-security": "node scripts/check-electron-security.mjs",
    "check:flatpak": "node scripts/check-flatpak.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:ipc-contract": "node scripts/check-ipc-contract.mjs",
    "check:licenses": "license-checker-rseidelsohn --summary --excludePrivatePackages",
    "check:log-injection": "node scripts/check-log-injection.mjs",
    "check:log-panel-filter": "node scripts/check-log-panel-filter.mjs",
    "check:log-service-sinks": "node scripts/check-log-service-sinks.mjs",
    "check:protocol-string-gates": "node scripts/check-protocol-string-gates.mjs",
    "check:silent-catches": "node scripts/check-silent-catches.mjs",
    "check:url-hostname-sanitization": "node scripts/check-url-hostname-sanitization.mjs",
    "check:xss-patterns": "node scripts/check-xss-patterns.mjs",
    "clean": "rm -rf dist-electron dist node_modules",
    "dedupe:dist": "pnpm dedupe --config.ignore-scripts=true",
    "dev": "node scripts/run-dev.mjs",
    "predist": "pnpm run dedupe:dist",
    "dist": "pnpm run build && electron-builder --publish never",
    "dist:linux": "pnpm run dedupe:dist && pnpm run build && electron-builder --linux --x64 --arm64 --publish never",
    "dist:linux:publish": "pnpm run dedupe:dist && pnpm run build && electron-builder --linux --x64 --arm64 --publish always",
    "dist:mac": "pnpm run dedupe:dist && pnpm run build && electron-builder --mac --publish never",
    "dist:mac:publish": "pnpm run dedupe:dist && pnpm run build && electron-builder --mac --publish always",
    "dist:win": "pnpm run build && pnpm install --config.node-linker=hoisted && electron-builder --win --publish never && node scripts/dist-win-restore-node-modules.mjs",
    "dist:win:publish": "pnpm run build && pnpm install --config.node-linker=hoisted && electron-builder --win --publish always && node scripts/dist-win-restore-node-modules.mjs",
    "docs:build": "node scripts/run-mkdocs.mjs build",
    "docs:install": "node scripts/install-mkdocs-deps.mjs",
    "docs:serve": "node scripts/run-mkdocs.mjs serve",
    "electron:open": "node scripts/start-electron.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md,sh}\" && sort-package-json --ignore \"**/*.md\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md,sh}\" && sort-package-json --check --ignore \"**/*.md\"",
    "i18n:auto-translate": "node scripts/i18n-auto-translate.mjs",
    "preinstall": "pnpm dlx only-allow pnpm",
    "postinstall": "node scripts/rebuild-native.mjs",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "prepare": "git config core.hooksPath .githooks",
    "rebuild": "node scripts/rebuild-native.mjs",
    "setup:actionlint": "node scripts/install-actionlint.mjs",
    "setup:build-deps": "node scripts/setup-build-deps.mjs",
    "setup:dialout": "node scripts/setup-dialout.mjs",
    "start": "pnpm run build && ELECTRON_ENABLE_SECURITY_WARNINGS=1 node scripts/start-electron.mjs",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "test:verbose": "vitest run --reporter=verbose",
    "trace-deprecation": "pnpm run build && NODE_OPTIONS='--trace-deprecation' node scripts/start-electron.mjs",
    "typecheck": "pnpm exec tsc --noEmit && pnpm exec tsc --noEmit -p tsconfig.main.json",
    "typecheck:strict-shared": "pnpm exec tsc --noEmit -p tsconfig.strict.json"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@meshtastic/protobufs": "npm:@jsr/meshtastic__protobufs@^2.7.23",
    "@stoprocent/noble": "^2.5.3",
    "builder-util-runtime": "9.7.0",
    "electron-updater": "^6.8.9",
    "emoji-picker-element": "^1.29.1",
    "i18next": "^26.3.1",
    "jszip": "^3.10.1",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react-motion": "^0.4.0",
    "mesh-client": "link:",
    "mgrs": "^2.1.0",
    "motion": "^12.40.0",
    "mqtt": "^5.15.1",
    "node-forge": "^1.4.0",
    "react-i18next": "^17.0.8",
    "react-leaflet-cluster": "^4.1.3",
    "readable-stream": "^4.7.0",
    "semver": "7.7.4",
    "systeminformation": "^5.31.7"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@liamcottle/meshcore.js": "^1.13.0",
    "@meshtastic/core": "npm:@jsr/meshtastic__core@^2.6.6",
    "@meshtastic/transport-http": "npm:@jsr/meshtastic__transport-http@^0.2.1",
    "@meshtastic/transport-web-serial": "npm:@jsr/meshtastic__transport-web-serial@^0.2.5",
    "@michaelhart/meshcore-decoder": "^0.3.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-virtual": "^3.14.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.9.3",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^9.2.1",
    "electron": "^41.7.2",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-electron": "^7.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jsdom": "^29.1.1",
    "leaflet": "^1.9.4",
    "license-checker-rseidelsohn": "^4.4.2",
    "markdownlint-cli2": "^0.22.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-sh": "^0.18.1",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "resedit": "^1.7.2",
    "sort-package-json": "^3.7.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vitest-axe": "1.0.0-pre.5",
    "zustand": "^5.0.14"
  },
  "packageManager": "pnpm@10.34.3+sha512.f2c531b08829d7be7f03c90addc266615f9c5477463e4bf1d275cb263ce9ea57cf0d5599110d94649a9bb3fed9f0b5efcea74a7016b61532a24cb9ad87860c1d",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "10"
      }
    },
    "onlyBuiltDependencies": [
      "@meshtastic/core",
      "@serialport/bindings-cpp",
      "@stoprocent/bluetooth-hci-socket",
      "@stoprocent/noble",
      "electron",
      "electron-winstaller",
      "esbuild",
      "usb"
    ],
    "overrides": {
      "@babel/core": "^7.29.6",
      "@electron/asar": "^4.0.1",
      "@meshtastic/core": "npm:@jsr/meshtastic__core@^2.6.6",
      "cacheable-request": "^10.0.0",
      "form-data": "^4.0.6",
      "js-yaml": "^4.2.0",
      "shell-quote": "^1.8.4",
      "tar": "^7.5.16",
      "tmp": "^0.2.6",
      "ws": "^8.21.0"
    },
    "patchedDependencies": {
      "@jsr/meshtastic__core@2.6.6": "patches/@jsr__meshtastic__core@2.6.6.patch",
      "@jsr/meshtastic__transport-web-serial@0.2.5": "patches/@jsr__meshtastic__transport-web-serial@0.2.5.patch",
      "@liamcottle/meshcore.js@1.13.0": "patches/@liamcottle__meshcore.js@1.13.0.patch",
      "@stoprocent/noble@2.5.3": "patches/@stoprocent__noble@2.5.3.patch",
      "debug@4.4.3": "patches/debug@4.4.3.patch",
      "readable-stream@4.7.0": "patches/readable-stream@4.7.0.patch",
      "usb@2.18.0": "patches/usb@2.18.0.patch"
    },
    "minimumReleaseAgeExclude": [
      "lodash",
      "lodash-es"
    ]
  }
}
